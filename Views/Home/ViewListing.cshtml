@model CollegeMarketplaceMarch2026.Models.ListingModel
@{
    ViewBag.Title = "Listing Details";
}

<main>
    <div class="container mt-4">

        <h3 class="mb-4">Listing Details</h3>

        <div class="card p-4">

            <h4>@Model.ItemName</h4>
            <p class="text-muted">$@Model.SellPrice</p>

            <hr />

            <p>@Model.ItemDesc</p>

            <p><strong>Category:</strong> @Model.ItemType</p>
            <p><strong>Posted:</strong> @Model.DateListed.ToShortDateString()</p>

            <hr />

            <!-- Images -->
            @if (Model.ListingImages != null && Model.ListingImages.Any())
            {
                <div class="row">
                    @foreach (var img in Model.ListingImages)
                    {
                        var base64 = Convert.ToBase64String(img);
                        var imgSrc = String.Format("data:image/png;base64,{0}", base64);

                        <div class="col-md-3 mb-3">
                            <img src="@imgSrc" class="img-fluid rounded" />
                        </div>
                    }
                </div>
            }

            <div class="mt-3">
                @Html.ActionLink("Edit", "EditListing", new { id = Model.ListingID }, new { @class = "btn btn-warning" })
                @Html.ActionLink("Back", "Index", null, new { @class = "btn btn-secondary" })
            </div>

        </div>

    </div>
</main>