@using CollegeMarketplaceMarch2026.Models
@model CollegeMarketplaceMarch2026.Models.ListingModel
@{
    ViewBag.Title = "Listing Details";
}

<main>
    <div class="container mt-4">

        <h3 class="mb-4">Listing Details</h3>

        <div class="card p-4">

            <h4>@Model.ItemName</h4>
            <p class="text-muted">$@Model.SellPrice</p>

            <hr />

            <p>@Model.ItemDesc</p>

            <p><strong>Category:</strong> @Model.ItemType</p>
            <p><strong>Posted:</strong> @Model.DateListed.ToShortDateString()</p>

            <hr />

            <!-- Images -->
            @if (Model.ListingImages != null && Model.ListingImages.Any())
            {
                <div class="row">
                    @foreach (var img in Model.ListingImages)
                    {
                        var base64 = Convert.ToBase64String(img.ImageData);
                        var imgSrc = $"data:{img.ContentType};base64,{base64}";

                        <div class="col-md-3 mb-3">
                            <img src="@imgSrc" class="img-fluid rounded" />
                        </div>
                    }
                </div>
            }

        <div class="mt-3">
            @{UserModel user = (UserModel)Session["User"];}
            @if (Model.UserID != user.UserID)
            {
                <form asp-controller="Home" asp-action="ViewListing" method="post" class="d-inline">
                    <input type="hidden" name="listingId" value="@Model.ListingID" />
                    <button type="submit" class="btn btn-success">Purchase</button>
                </form>
            }

            @Html.ActionLink("Back", "Index", null, new { @class = "btn btn-secondary ms-2" })
        </div>

        </div>

    </div>
</main>