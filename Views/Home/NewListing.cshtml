@model CollegeMarketplaceMarch2026.Models.ListingModel
@{
    ViewBag.Title = "New Listing";
}

<main aria-labelledby="title">

    <div class="container mt-4">

        <h3 class="mb-4">Create a Listing</h3>

        @using (Html.BeginForm("NewListing", "Home", FormMethod.Post, new { enctype = "multipart/form-data" }))
        {

            <div class="mb-3">
                <label class="form-label">Listing Title</label>
                @Html.TextBoxFor(m => m.ItemName, new { @class = "form-control", placeholder = "Enter listing title" })
            </div>

            <div class="mb-3">
                <label class="form-label">Listing Price</label>
                @Html.TextBoxFor(m => m.SellPrice, new { @class = "form-control", type = "number", step = "0.01", placeholder = "0.00" })
            </div>

            <div class="mb-3">
                <label class="form-label">Listing Description</label>
                @Html.TextAreaFor(m => m.ItemDesc, new { @class = "form-control", rows = 4, placeholder = "Describe your item..." })
            </div>

            <div class="mb-3">
                @Html.DropDownListFor(m => m.ItemType, new List<SelectListItem>
                {
                    new SelectListItem { Text = "Select a category", Value = "" },
                    new SelectListItem { Text = "Textbooks", Value = "Textbooks" },
                    new SelectListItem { Text = "Merchandise", Value = "Merchandise" },
                    new SelectListItem { Text = "Materials", Value = "Materials" }
                }, new { @class = "form-select" })
            </div>

            <div class="mb-3">
                <label class="form-label">Upload Images</label>
                <input type="file" name="ListingImages" class="form-control" multiple />
            </div>

            <button type="submit" class="btn btn-primary w-100">Post Listing</button>


        }

    </div>

</main>