@{
    ViewBag.Title = "New Listing";
}

<main aria-labelledby="title">

    <div class="container mt-4">

        <h3 class="mb-4">Create a Listing</h3>

        <form>

            <div class="mb-3">
                <label class="form-label">Listing Title</label>
                <input type="text" class="form-control" placeholder="Enter listing title">
            </div>

            <div class="mb-3">
                <label class="form-label">Listing Price</label>
                <input type="number" step="0.01" class="form-control" placeholder="0.00">
            </div>

            <div class="mb-3">
                <label class="form-label">Listing Description</label>
                <textarea class="form-control" rows="4"
                          placeholder="Describe your item..."></textarea>
            </div>

            <div class="mb-3">
                <label class="form-label">Listing Category</label>
                <select class="form-select">
                    <option selected>Select a category</option>
                    <option>Textbooks</option>
                    <option>Merchandise</option>
                    <option>Materials</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Upload Images</label>
                <input type="file" class="form-control" multiple>
            </div>

            <button class="btn btn-primary">
                Post Listing
            </button>

        </form>

    </div>

</main>